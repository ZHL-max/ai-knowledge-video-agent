# Project
AKVA_PROJECT_ROOT=.
AKVA_DATA_DIR=./data/runs
AKVA_PUBLIC_BASE_URL=http://localhost:5173

# Runtime providers: mock | openai-compatible
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# TTS providers: edge | mock | openai
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=-4%
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Douyin Open Platform. Leave empty to export a manual publish package.
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_ACCESS_TOKEN=
DOUYIN_OPEN_ID=
